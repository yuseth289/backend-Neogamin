        {
          "name": "Iniciar sesión",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "const token = response.token || response.accessToken;",
                  "",
                  "if (token) {",
                  "    pm.environment.set(\"token\", token);",
                  "    console.log(\"Token guardado automáticamente\");",
                  "}",
                  "",
                  "const idUsuario = response.usuarioId || response.idUsuario || response.userId;",
                  "if (idUsuario) {",
                  "    pm.environment.set(\"idUsuario\", String(idUsuario));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"carlos@gmail.com\",\n  \"password\": \"Carlos123*\"\n}"
